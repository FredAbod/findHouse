NODE_ENV=development
PORT=5000
JWT_SECRET=change-me

# MongoDB
MONGO_URI=

# Must match your live SPA origin (scheme + hostname, no trailing path). Email verification links use this.
FRONTEND_URL=http://localhost:8080

# Paystack — same secret verifies webhooks AND signs API requests
PAYSTACK_SECRET_KEY=

# Free tier — max NEW listings created per UTC calendar day for non-Pro users (override per environment).
FREE_TIER_DAILY_LISTING_CREATES=3
# Legacy fallback when the above is unset:
# FREE_TIER_PROPERTY_LIMIT=3

# Pro checkout amount in Naira (converted to kobo internally)
PAYSTACK_PRO_AMOUNT_NGN=5000
