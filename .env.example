NODE_ENV=development
PORT=5000
JWT_SECRET=change-me

# MongoDB
MONGO_URI=

# Frontend (links in emails / Paystack redirects)
FRONTEND_URL=http://localhost:8080

# Paystack — same secret verifies webhooks AND signs API requests
PAYSTACK_SECRET_KEY=

# Free tier caps (matching marketing — override per environment)
FREE_TIER_PROPERTY_LIMIT=3

# Pro checkout amount in Naira (converted to kobo internally)
PAYSTACK_PRO_AMOUNT_NGN=5000
